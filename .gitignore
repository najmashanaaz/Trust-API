# .gitignore — tells Git which files to NOT track
# Without this, sensitive info and clutter would end up in your repository.

# Python bytecode compiled by the interpreter — not needed in source control
__pycache__/
*.py[cod]
*.pyo

# Virtual environment folder — these can be 100 MB+; each dev installs their own
venv/
.venv/
env/

# The SQLite database file — this is runtime data, not source code
database/monitor.db

# Environment variables file — contains secrets like email passwords (Phase 3)
.env

# OS clutter
.DS_Store
Thumbs.db

# Editor folders
.vscode/
.idea/
