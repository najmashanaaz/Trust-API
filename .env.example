# ──────────────────────────────────────────────────────────────────────────────
# .env.example  —  copy this file to .env and fill in real values.
# .env is listed in .gitignore and must NEVER be committed.
# ──────────────────────────────────────────────────────────────────────────────

# Gmail credentials for outage/failover email alerts.
# Use a Gmail App Password (not your real password).
# Generate one at: https://myaccount.google.com/apppasswords (requires 2FA).
GMAIL_USER=your_email@gmail.com
GMAIL_PASSWORD=your_16_char_app_password

# JWT secret key for signing auth tokens.
# Change this to a long random string in production.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=trustapi-secret-key-change-in-production

# Set to "1" to run the monitoring scheduler inside the FastAPI process.
# Leave as "0" (default) and run  python run_monitor.py  in a separate terminal.
EMBED_SCHEDULER=0
